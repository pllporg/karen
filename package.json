{
  "name": "karen-legal-suite",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"pnpm --filter api dev\" \"pnpm --filter web dev\"",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:provider-live": "pnpm --filter api test:provider-live",
    "test:integrations-live": "pnpm --filter api test:connectors-live",
    "ops:drill:backup-restore": "node tools/ops/backup_restore_rollback_drill.mjs",
    "ops:evidence:capture": "node tools/ops/capture_provider_status_evidence.mjs",
    "ops:symphony:handoff:check": "node tools/ops/check_symphony_handoff.mjs",
    "perf:web:evidence": "node tools/perf/capture_web_perf_evidence.mjs",
    "perf:web:stability": "pnpm --filter web test:stability",
    "ops:preflight": "node tools/ops/operator_preflight.mjs",
    "ops:housekeeping": "pnpm backlog:sync && pnpm backlog:verify && pnpm backlog:matrix:check && pnpm backlog:snapshot && pnpm backlog:handoff:refresh && pnpm backlog:handoff:check",
    "ops:readiness:evidence": "pnpm ops:drill:backup-restore && pnpm ops:evidence:capture",
    "test:ui-regression": "pnpm ui:contract:check && pnpm --filter web test:regression && pnpm --filter web build",
    "ui:contract:check": "node tools/ui/check_lic_style_guards.mjs",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "backlog:github:bootstrap": "node tools/backlog-sync/bootstrap_github_repo.mjs",
    "backlog:linear:setup": "node tools/backlog-sync/setup_linear_workspace.mjs",
    "backlog:seed": "node tools/backlog-sync/seed_parity_backlog.mjs",
    "backlog:sync": "node tools/backlog-sync/linear_to_github.mjs",
    "backlog:ui:sync": "node tools/backlog-sync/sync_ui_refactor_backlog.mjs",
    "backlog:verify": "node tools/backlog-sync/verify_backlog_sync.mjs",
    "backlog:matrix:check": "node tools/backlog-sync/check_matrix_linear_alignment.mjs",
    "backlog:snapshot": "node tools/backlog-sync/backlog_snapshot.mjs",
    "backlog:handoff:refresh": "node tools/backlog-sync/refresh_handoff_from_snapshot.mjs",
    "backlog:handoff:check": "node tools/backlog-sync/check_handoff_freshness.mjs",
    "backlog:bootstrap:check": "pnpm backlog:verify && pnpm backlog:matrix:check && pnpm backlog:snapshot",
    "rc1:lane:a:verify": "pnpm --filter api lint && pnpm --filter api test:core-workflow && pnpm --filter api test && pnpm --filter web test && pnpm build",
    "rc1:lane:b:verify": "pnpm --filter web test && pnpm --filter api test && pnpm build",
    "rc1:orchestrator:post-merge": "pnpm backlog:sync && pnpm backlog:verify && pnpm backlog:snapshot && pnpm backlog:handoff:refresh && pnpm backlog:handoff:check",
    "docs:req-ui-009:check": "node tools/backlog-sync/check_req_ui_009_docs.mjs",
    "ops:release:smoke": "node tools/ops/run_release_smoke.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  }
}
