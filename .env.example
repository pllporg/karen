# Shared
NODE_ENV=development

# API
API_PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/karen?schema=public
REDIS_URL=redis://localhost:6379
SESSION_SECRET=replace-me-with-long-random-secret
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_BUCKET=karen-docs
S3_FORCE_PATH_STYLE=true
MALWARE_SCANNER_PROVIDER=stub
MALWARE_SCANNER_FAIL_OPEN=false
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_MS=10000
CLAMAV_MAX_BYTES=26214400
CLAMAV_CHUNK_SIZE=65536
# OAuth/integration token encryption (required for production)
# format: key-id:base64-32-byte-key[,key-id-2:base64-32-byte-key]
INTEGRATION_TOKEN_ENCRYPTION_KEYS=
INTEGRATION_TOKEN_ACTIVE_KEY_ID=
# integration oauth connector config (live mode optional; defaults to stub mode)
INTEGRATION_OAUTH_ENABLE_LIVE=false
CLIO_CLIENT_ID=
CLIO_CLIENT_SECRET=
CLIO_AUTH_URL=https://app.clio.com/oauth/authorize
CLIO_TOKEN_URL=https://app.clio.com/oauth/token
MYCASE_CLIENT_ID=
MYCASE_CLIENT_SECRET=
MYCASE_AUTH_URL=https://auth.mycase.com/oauth/authorize
MYCASE_TOKEN_URL=https://auth.mycase.com/oauth/token
# integration sync connector config (live pull optional; defaults to scaffold mode)
INTEGRATION_SYNC_ENABLE_LIVE=false
CLIO_API_BASE_URL=https://app.clio.com/api/v4
MYCASE_API_BASE_URL=https://api.mycase.com/v1
FILEVINE_API_BASE_URL=https://api.filevineapp.com
PRACTICEPANTHER_API_BASE_URL=https://app.practicepanther.com/api/v2
MYCASE_WEBHOOK_REGISTER_URL=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
WEB_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
