  severity              String?
  description           String?
  photoDocumentVersionIds String[] @default([])
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  matter                Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)
}

model DamagesItem {
  id                 String   @id @default(uuid()) @db.Uuid
  organizationId     String   @db.Uuid
  matterId           String   @db.Uuid
  category           String
  repairEstimate     Float?
  paidAmount         Float?
  completionCost     Float?
  consequentialAmount Float?
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  matter             Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)
}

model LienModel {
  id               String   @id @default(uuid()) @db.Uuid
  organizationId   String   @db.Uuid
  matterId         String   @db.Uuid
  claimantContactId String? @db.Uuid
  amount           Float
  recordingDate    DateTime?
  releaseDate      DateTime?
  status           String
  documentId       String?  @db.Uuid
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  matter           Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)
  claimantContact  Contact? @relation("LienClaimant", fields: [claimantContactId], references: [id], onDelete: SetNull)
  document         Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)
}

model InsuranceClaim {
  id                String   @id @default(uuid()) @db.Uuid
  organizationId    String   @db.Uuid
  matterId          String   @db.Uuid
  policyNumber      String?
  claimNumber       String?
  adjusterContactId String?  @db.Uuid
  insurerContactId  String?  @db.Uuid
  coverageNotes     String?
  status            String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  matter            Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)
  adjusterContact   Contact? @relation("InsuranceAdjuster", fields: [adjusterContactId], references: [id], onDelete: SetNull)
  insurerContact    Contact? @relation("InsuranceInsurer", fields: [insurerContactId], references: [id], onDelete: SetNull)
}

model ExpertEngagement {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @db.Uuid
  matterId        String   @db.Uuid
  expertContactId String   @db.Uuid
  scope           String?
  feeArrangement  String?
  reportDocumentId String? @db.Uuid
  status          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  matter          Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)
  expertContact   Contact  @relation(fields: [expertContactId], references: [id], onDelete: Cascade)
  reportDocument  Document? @relation(fields: [reportDocumentId], references: [id], onDelete: SetNull)
}

model IntegrationConnection {
  id                  String                    @id @default(uuid()) @db.Uuid
  organizationId      String                    @db.Uuid
  provider            IntegrationProvider
  name                String
  status              IntegrationConnectionStatus @default(CONNECTED)
  encryptedAccessToken String?
  encryptedRefreshToken String?
  tokenExpiresAt      DateTime?
  scopes              String[]                  @default([])
  configJson          Json?
  lastSyncAt          DateTime?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  syncRuns            IntegrationSyncRun[]
  webhookSubscriptions IntegrationWebhookSubscription[]

  @@index([organizationId, provider])
}

model IntegrationSyncRun {
  id             String                @id @default(uuid()) @db.Uuid
  organizationId String                @db.Uuid
  connectionId   String                @db.Uuid
  idempotencyKey String
  status         IntegrationSyncStatus @default(QUEUED)
  cursor         String?
  startedAt      DateTime?             
  finishedAt     DateTime?
  error          String?
  createdAt      DateTime              @default(now())
  connection     IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, idempotencyKey])
  @@index([organizationId, status])
}

model IntegrationWebhookSubscription {
  id             String                    @id @default(uuid()) @db.Uuid
  organizationId String                    @db.Uuid
  connectionId   String                    @db.Uuid
  event          String
  targetUrl      String
  status         IntegrationWebhookStatus  @default(ACTIVE)
  externalId     String?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  connection     IntegrationConnection     @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, event, targetUrl])
}

model WebhookEndpoint {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  url            String
  secret         String
  events         String[] @default([])
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deliveries     WebhookDelivery[]
}

model WebhookDelivery {
  id               String   @id @default(uuid()) @db.Uuid
  webhookEndpointId String  @db.Uuid
  eventType        String
  payloadJson      Json
  status           String
  idempotencyKey   String
  attemptCount     Int      @default(0)
  responseCode     Int?
  lastAttemptAt    DateTime?
  createdAt        DateTime @default(now())
  webhookEndpoint  WebhookEndpoint @relation(fields: [webhookEndpointId], references: [id], onDelete: Cascade)

  @@index([webhookEndpointId, status])
}

model ExportJob {
  id               String        @id @default(uuid()) @db.Uuid
  organizationId   String        @db.Uuid
  requestedByUserId String?      @db.Uuid
  exportType       String
  status           ExportJobStatus @default(QUEUED)
  storageKey       String?
  summaryJson      Json?
  error            String?
  createdAt        DateTime      @default(now())
  finishedAt       DateTime?
  requestedBy      User?         @relation(fields: [requestedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
}
