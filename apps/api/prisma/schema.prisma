generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum ContactKind {
  PERSON
  ORGANIZATION
}

enum ContactMethodType {
  EMAIL
  PHONE
  ADDRESS
  SOCIAL
}

enum MatterStatus {
  OPEN
  PENDING
  CLOSED
  ARCHIVED
}

enum MatterParticipantSide {
  CLIENT_SIDE
  OPPOSING_SIDE
  NEUTRAL
  COURT
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELED
}

enum CommunicationMessageType {
  EMAIL
  SMS
  CALL_LOG
  PORTAL_MESSAGE
  INTERNAL_NOTE
}

enum CommunicationDirection {
  INBOUND
  OUTBOUND
  INTERNAL
}

enum CommunicationParticipantRole {
  FROM
  TO
  CC
  BCC
  OTHER
}

enum DocumentConfidentiality {
  PUBLIC
  INTERNAL
  CONFIDENTIAL
  HIGHLY_CONFIDENTIAL
}

enum DocumentDispositionStatus {
  ACTIVE
  PENDING_DISPOSITION
  DISPOSED
}

enum RetentionScope {
  ALL_DOCUMENTS
  MATTER
  CATEGORY
}

enum RetentionTrigger {
  DOCUMENT_UPLOADED
  MATTER_CLOSED
}

enum DocumentLegalHoldStatus {
  ACTIVE
  RELEASED
}

enum DocumentDispositionRunStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  COMPLETED
  CANCELED
}

enum DocumentDispositionItemStatus {
  PENDING
  SKIPPED_LEGAL_HOLD
  DISPOSED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  VOID
  OVERDUE
}

enum PaymentMethod {
  STRIPE
  MANUAL
  CHECK
  ACH
  CASH
}

enum TrustTransactionType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER
  ADJUSTMENT
}

enum TrustReconciliationRunStatus {
  DRAFT
  IN_REVIEW
  COMPLETED
}

enum TrustReconciliationDiscrepancyStatus {
  OPEN
  RESOLVED
  WAIVED
}

enum LeadStage {
  NEW
  SCREENING
  CONFLICT_CHECK
  CONSULTATION
  RETAINED
  REJECTED
}

enum AiJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum AiArtifactReviewStatus {
  DRAFT
  APPROVED
  REJECTED
}

enum ImportBatchStatus {
  QUEUED
  RUNNING
  PARTIAL
  COMPLETED
  FAILED
}

enum ImportItemStatus {
  PENDING
  IMPORTED
  FAILED
  SKIPPED
}

enum IntegrationProvider {
  CLIO
  MYCASE
  FILEVINE
  PRACTICEPANTHER
  GMAIL
  OUTLOOK
  GENERIC_REST
}

enum IntegrationConnectionStatus {
  CONNECTED
  ERROR
  DISCONNECTED
}

enum IntegrationSyncStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum IntegrationWebhookStatus {
  ACTIVE
  ERROR
  DISABLED
}

enum ExportJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

model Organization {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  slug         String   @unique
  settingsJson Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model User {
  id                 String              @id @default(uuid()) @db.Uuid
  email              String              @unique
  passwordHash       String
  fullName           String?
  mfaSecret          String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  memberships        Membership[]
  sessions           Session[]
  auditEvents        AuditLogEvent[]
  communicationMessagesCreated CommunicationMessage[]
  matterTeamMembers  MatterTeamMember[]
  matterDenyEntries  MatterAccessDeny[]
  tasksAssigned      Task[]              @relation("TaskAssignee")
  tasksCreated       Task[]              @relation("TaskCreator")
  reminders          Reminder[]
  notifications      Notification[]
  documentsCreated   Document[]
  documentVersions   DocumentVersion[]
  documentShareLinks DocumentShareLink[]
  retentionPoliciesCreated DocumentRetentionPolicy[]
  documentLegalHoldsPlaced DocumentLegalHold[] @relation("DocumentLegalHoldPlacedBy")
  documentLegalHoldsReleased DocumentLegalHold[] @relation("DocumentLegalHoldReleasedBy")
  documentDispositionRunsRequested DocumentDispositionRun[] @relation("DocumentDispositionRunRequestedBy")
  documentDispositionRunsApproved DocumentDispositionRun[] @relation("DocumentDispositionRunApprovedBy")
  documentDispositionRunsExecuted DocumentDispositionRun[] @relation("DocumentDispositionRunExecutedBy")
  timeEntries        TimeEntry[]
  expenses           Expense[]
  leadsAssigned      Lead[]
  conflictChecks     ConflictCheckResult[]
  aiJobsCreated      AiJob[]
  aiArtifactsReviewed AiArtifact[]
  aiExecutionLogs    AiExecutionLog[]
  sectionInstancesUpdated SectionInstance[]
  importBatchesStarted ImportBatch[]
  exportJobsRequested ExportJob[]
  trustReconciliationRunsCreated TrustReconciliationRun[] @relation("TrustReconciliationRunCreatedBy")
  trustReconciliationRunsSignedOff TrustReconciliationRun[] @relation("TrustReconciliationRunSignedOffBy")
  trustReconciliationDiscrepanciesResolved TrustReconciliationDiscrepancy[] @relation("TrustReconciliationDiscrepancyResolvedBy")
}

model Membership {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @db.Uuid
  userId         String           @db.Uuid
  roleId         String?          @db.Uuid
  contactId      String?          @db.Uuid
  status         MembershipStatus @default(ACTIVE)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           Role?            @relation(fields: [roleId], references: [id], onDelete: SetNull)
  contact        Contact?         @relation(fields: [contactId], references: [id], onDelete: SetNull)
  sessions       Session[]

  @@unique([organizationId, userId])
  @@index([organizationId])
}

model Role {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  name           String
  description    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  memberships    Membership[]
  permissions    Permission[] @relation("RolePermissions")

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Permission {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  key            String
  label          String
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  roles          Role[]   @relation("RolePermissions")

  @@unique([organizationId, key])
  @@index([organizationId])
}

model Session {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid
  organizationId String   @db.Uuid
  membershipId   String   @db.Uuid
  tokenHash      String   @unique
  expiresAt      DateTime
  revokedAt      DateTime?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  membership     Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model AccessPolicy {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  resourceType   String
  effect         String
  conditionsJson Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId, resourceType])
}

model AuditLogEvent {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  actorUserId    String?  @db.Uuid
  action         String
  entityType     String
  entityId       String
  metadataJson   Json?
  previousHash   String?
  eventHash      String
  createdAt      DateTime @default(now())
  actorUser      User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@unique([organizationId, eventHash])
}

model Contact {
  id                     String                     @id @default(uuid()) @db.Uuid
  organizationId         String                     @db.Uuid
  kind                   ContactKind
  displayName            String
  primaryEmail           String?
  primaryPhone           String?
  tags                   String[]                   @default([])
  rawSourcePayload       Json?
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
  personProfile          PersonProfile?
  organizationProfile    OrganizationProfile?
  methods                ContactMethod[]
  outgoingRelationships  ContactRelationship[]      @relation("ContactRelationshipFrom")
  incomingRelationships  ContactRelationship[]      @relation("ContactRelationshipTo")
  matterParticipants     MatterParticipant[]        @relation("MatterParticipantContact")
  representedParticipants MatterParticipant[]       @relation("ParticipantRepresentedBy")
  lawFirmParticipants    MatterParticipant[]        @relation("ParticipantLawFirm")
  memberships            Membership[]
  communicationThreads   CommunicationThread[]
  communicationParticipants CommunicationParticipant[]
  leadsReferred          Lead[]                     @relation("LeadReferralContact")
  insuranceClaimsAdjuster InsuranceClaim[]          @relation("InsuranceAdjuster")
  insuranceClaimsInsurer InsuranceClaim[]           @relation("InsuranceInsurer")
  lienClaims             LienModel[]                @relation("LienClaimant")
  expertEngagements      ExpertEngagement[]

  @@index([organizationId])
  @@index([primaryEmail])
  @@index([primaryPhone])
}

model PersonProfile {
  id                 String  @id @default(uuid()) @db.Uuid
  contactId          String  @unique @db.Uuid
  firstName          String?
  lastName           String?
  barNumber          String?
  licenseJurisdiction String?
  title              String?
  contact            Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model OrganizationProfile {
  id        String  @id @default(uuid()) @db.Uuid
  contactId String  @unique @db.Uuid
  legalName String
  dba       String?
  website   String?
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model ContactMethod {
  id          String            @id @default(uuid()) @db.Uuid
  contactId   String            @db.Uuid
  type        ContactMethodType
  value       String
  label       String?
  isPrimary   Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  contact     Contact           @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model ContactRelationship {
  id               String   @id @default(uuid()) @db.Uuid
  organizationId   String   @db.Uuid
  fromContactId    String   @db.Uuid
  toContactId      String   @db.Uuid
  relationshipType String
  notes            String?
  createdAt        DateTime @default(now())
  fromContact      Contact  @relation("ContactRelationshipFrom", fields: [fromContactId], references: [id], onDelete: Cascade)
  toContact        Contact  @relation("ContactRelationshipTo", fields: [toContactId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model MatterType {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  name           String
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  matters        Matter[]
  sectionDefinitions SectionDefinition[]

  @@unique([organizationId, name])
}

model MatterStage {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  practiceArea   String
  name           String
  orderIndex     Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  matters        Matter[]
  stageAutomationsFrom StageAutomation[] @relation("StageAutomationFrom")
  stageAutomationsTo   StageAutomation[] @relation("StageAutomationTo")

  @@index([organizationId, practiceArea, orderIndex])
}

model ParticipantRoleDefinition {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  key            String
  label          String
  description    String?
  sideDefault    MatterParticipantSide?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  participants   MatterParticipant[]

  @@unique([organizationId, key])
}

model Matter {
  id                   String                @id @default(uuid()) @db.Uuid
  organizationId       String                @db.Uuid
  matterNumber         String
  name                 String
  practiceArea         String
  jurisdiction         String?
  venue                String?
  stageId              String?               @db.Uuid
  matterTypeId         String?               @db.Uuid
  status               MatterStatus          @default(OPEN)
  ethicalWallEnabled   Boolean               @default(false)
  openedAt             DateTime              @default(now())
  closedAt             DateTime?
  rawSourcePayload     Json?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  stage                MatterStage?          @relation(fields: [stageId], references: [id], onDelete: SetNull)
  matterType           MatterType?           @relation(fields: [matterTypeId], references: [id], onDelete: SetNull)
  participants         MatterParticipant[]
  relatedFrom          MatterRelationship[]  @relation("MatterRelationshipFrom")
  relatedTo            MatterRelationship[]  @relation("MatterRelationshipTo")
  teams                MatterTeam[]
  teamMembers          MatterTeamMember[]
  denyUsers            MatterAccessDeny[]
  sectionInstances     SectionInstance[]
  tasks                Task[]
  reminders            Reminder[]
  calendarEvents       CalendarEvent[]
  serviceEvents        ServiceEvent[]
  docketEntries        DocketEntry[]
  communicationThreads CommunicationThread[]
  documentFolders     DocumentFolder[]
  documents            Document[]
  documentRetentionPolicies DocumentRetentionPolicy[]
  documentLegalHolds  DocumentLegalHold[]
  evidenceItems        EvidenceItem[]
  timeEntries          TimeEntry[]
  expenses             Expense[]
  invoices             Invoice[]
  trustTransactions    TrustTransaction[]
  trustLedgers         MatterTrustLedger[]
  trustReconciliationDiscrepancies TrustReconciliationDiscrepancy[]
  intakeSubmissions    IntakeSubmission[]
  eSignEnvelopes       ESignEnvelope[]
  aiJobs               AiJob[]
  propertyProfile      PropertyProfile?
  contractProfile      ContractProfile?
  projectMilestones    ProjectMilestone[]
  defectIssues         DefectIssue[]
  damagesItems         DamagesItem[]
  lienModels           LienModel[]
  insuranceClaims      InsuranceClaim[]
  expertEngagements    ExpertEngagement[]

  @@unique([organizationId, matterNumber])
  @@index([organizationId, status])
}

model MatterTeam {
  id        String            @id @default(uuid()) @db.Uuid
  matterId  String            @db.Uuid
  name      String
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  matter    Matter            @relation(fields: [matterId], references: [id], onDelete: Cascade)
  members   MatterTeamMember[]

  @@index([matterId])
}

model MatterTeamMember {
  id          String     @id @default(uuid()) @db.Uuid
  matterId    String     @db.Uuid
  matterTeamId String?   @db.Uuid
  userId      String     @db.Uuid
  canWrite    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  matter      Matter     @relation(fields: [matterId], references: [id], onDelete: Cascade)
  matterTeam  MatterTeam? @relation(fields: [matterTeamId], references: [id], onDelete: SetNull)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([matterId, userId])
  @@index([matterTeamId])
}

model MatterAccessDeny {
  id        String   @id @default(uuid()) @db.Uuid
  matterId  String   @db.Uuid
  userId    String   @db.Uuid
  reason    String?
  createdAt DateTime @default(now())
  matter    Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([matterId, userId])
}

model MatterParticipant {
  id                          String                @id @default(uuid()) @db.Uuid
  organizationId              String                @db.Uuid
  matterId                    String                @db.Uuid
  contactId                   String                @db.Uuid
  participantRoleKey          String
  participantRoleDefinitionId String?               @db.Uuid
  side                        MatterParticipantSide?
  isPrimary                   Boolean               @default(false)
  representedByContactId      String?               @db.Uuid
  lawFirmContactId            String?               @db.Uuid
  notes                       String?
  createdAt                   DateTime              @default(now())
  updatedAt                   DateTime              @updatedAt
  matter                      Matter                @relation(fields: [matterId], references: [id], onDelete: Cascade)
  contact                     Contact               @relation("MatterParticipantContact", fields: [contactId], references: [id], onDelete: Cascade)
  participantRoleDefinition   ParticipantRoleDefinition? @relation(fields: [participantRoleDefinitionId], references: [id], onDelete: SetNull)
  representedByContact        Contact?              @relation("ParticipantRepresentedBy", fields: [representedByContactId], references: [id], onDelete: SetNull)
  lawFirmContact              Contact?              @relation("ParticipantLawFirm", fields: [lawFirmContactId], references: [id], onDelete: SetNull)

  @@index([organizationId, matterId])
  @@index([participantRoleKey])
}

model MatterRelationship {
  id               String   @id @default(uuid()) @db.Uuid
  organizationId   String   @db.Uuid
  fromMatterId     String   @db.Uuid
  toMatterId       String   @db.Uuid
  relationshipType String
  notes            String?
  createdAt        DateTime @default(now())
  fromMatter       Matter   @relation("MatterRelationshipFrom", fields: [fromMatterId], references: [id], onDelete: Cascade)
  toMatter         Matter   @relation("MatterRelationshipTo", fields: [toMatterId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model CustomFieldDefinition {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @db.Uuid
  entityType      String
  key             String
  label           String
  fieldType       String
  optionsJson     Json?
  validationsJson Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  values          CustomFieldValue[]

  @@unique([organizationId, entityType, key])
}

model CustomFieldValue {
  id                String               @id @default(uuid()) @db.Uuid
  organizationId    String               @db.Uuid
  entityType        String
  entityId          String
  fieldDefinitionId String               @db.Uuid
  valueJson         Json
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  fieldDefinition   CustomFieldDefinition @relation(fields: [fieldDefinitionId], references: [id], onDelete: Cascade)

  @@unique([organizationId, entityType, entityId, fieldDefinitionId])
  @@index([organizationId, entityType, entityId])
}

model SectionDefinition {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  matterTypeId   String?  @db.Uuid
  name           String
  schemaJson     Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  matterType     MatterType? @relation(fields: [matterTypeId], references: [id], onDelete: SetNull)
  instances      SectionInstance[]
}

model SectionInstance {
  id                 String   @id @default(uuid()) @db.Uuid
  organizationId     String   @db.Uuid
  matterId           String   @db.Uuid
  sectionDefinitionId String  @db.Uuid
  dataJson           Json
  updatedByUserId    String?  @db.Uuid
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  matter             Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)
  sectionDefinition  SectionDefinition @relation(fields: [sectionDefinitionId], references: [id], onDelete: Cascade)
  updatedBy          User?    @relation(fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([matterId, sectionDefinitionId])
}

model TaskTemplate {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  name           String
  description    String?
  templateJson   Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model MatterTemplate {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  name           String
  matterTypeId   String?  @db.Uuid
  configJson     Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model StageAutomation {
  id             String      @id @default(uuid()) @db.Uuid
  organizationId String      @db.Uuid
  fromStageId    String?     @db.Uuid
  toStageId      String      @db.Uuid
  actionsJson    Json
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  fromStage      MatterStage? @relation("StageAutomationFrom", fields: [fromStageId], references: [id], onDelete: SetNull)
  toStage        MatterStage  @relation("StageAutomationTo", fields: [toStageId], references: [id], onDelete: Cascade)
}

model Task {
  id               String      @id @default(uuid()) @db.Uuid
  organizationId   String      @db.Uuid
  matterId         String      @db.Uuid
  title            String
  description      String?
  assigneeUserId   String?     @db.Uuid
  dueAt            DateTime?
  priority         TaskPriority @default(MEDIUM)
  status           TaskStatus   @default(TODO)
  checklistJson    Json?
  dependenciesJson Json?
  createdByUserId  String?      @db.Uuid
  rawSourcePayload Json?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  matter           Matter       @relation(fields: [matterId], references: [id], onDelete: Cascade)
  assignee         User?        @relation("TaskAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  createdBy        User?        @relation("TaskCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, matterId, dueAt])
}

model Reminder {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  matterId       String   @db.Uuid
  taskId         String?  @db.Uuid
  userId         String   @db.Uuid
  remindAt       DateTime
  channel        String
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
  matter         Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  userId         String   @db.Uuid
  type           String
  payloadJson    Json
  readAt         DateTime?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CalendarEvent {
  id               String   @id @default(uuid()) @db.Uuid
  organizationId   String   @db.Uuid
  matterId         String   @db.Uuid
  startAt          DateTime
  endAt            DateTime?
  type             String
  location         String?
  attendeesJson    Json?
  description      String?
  source           String?
  rawSourcePayload Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  matter           Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)

  @@index([organizationId, startAt])
}

model DeadlineRuleTemplate {
  id               String   @id @default(uuid()) @db.Uuid
  organizationId   String   @db.Uuid
  name             String
  triggerType      String
  offsetDays       Int
  businessDaysOnly Boolean  @default(false)
  configJson       Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ServiceEvent {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  matterId       String   @db.Uuid
  eventType      String
  occurredAt     DateTime
  detailsJson    Json?
  createdAt      DateTime @default(now())
  matter         Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)
}

model DocketEntry {
  id               String   @id @default(uuid()) @db.Uuid
  organizationId   String   @db.Uuid
  matterId         String   @db.Uuid
  filedAt          DateTime
  description      String
  sourceDocumentId String?  @db.Uuid
  createdAt        DateTime @default(now())
  matter           Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)
  sourceDocument   Document? @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
}

model CommunicationThread {
  id             String                 @id @default(uuid()) @db.Uuid
  organizationId String                 @db.Uuid
  matterId       String?                @db.Uuid
  contactId      String?                @db.Uuid
  subject        String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  matter         Matter?                @relation(fields: [matterId], references: [id], onDelete: SetNull)
  contact        Contact?               @relation(fields: [contactId], references: [id], onDelete: SetNull)
  messages       CommunicationMessage[]

  @@index([organizationId, matterId])
}

model CommunicationMessage {
  id               String                    @id @default(uuid()) @db.Uuid
  organizationId   String                    @db.Uuid
  threadId         String                    @db.Uuid
  type             CommunicationMessageType
  direction        CommunicationDirection
  subject          String?
  body             String
  occurredAt       DateTime                  @default(now())
  createdByUserId  String?                   @db.Uuid
  rawSourcePayload Json?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  thread           CommunicationThread       @relation(fields: [threadId], references: [id], onDelete: Cascade)
  createdBy        User?                     @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  participants     CommunicationParticipant[]
  attachments      CommunicationAttachment[]

  @@index([organizationId, occurredAt])
}

